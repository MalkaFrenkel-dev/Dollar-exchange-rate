FROM python:3.11-slim

WORKDIR /app

COPY . /app

RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r server_requirements.txt


EXPOSE 8000

CMD ["sh", "-c", "python -m db_access.init_db && uvicorn main:app --host 0.0.0.0 --port 8000 --reload"]
